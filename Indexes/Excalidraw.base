filters:
  and:
    - file.tags.contains("excalidraw")
    - '!file.path.contains("Template")'
views:
  - type: table
    name: Table
    order:
      - file.name
      - file.tags
      - purpose
      - status
      - related
      - file.mtime
    sort:
      - property: priority
        direction: DESC
  - type: cards
    name: Cards
    image: note.art
