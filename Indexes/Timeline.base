filters:
  and:
    - file.tags.contains("Timeline")
    - '!file.path.contains("Template")'
views:
  - type: table
    name: Table
    order:
      - file.name
      - status
      - related
      - scope
      - timelines
      - era
      - historical_scope
    columnSize:
      note.timelines: 134
      note.era: 168
  - type: cards
    name: Cards
    image: note.art
