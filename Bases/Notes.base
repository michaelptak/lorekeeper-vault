filters:
  and:
    - file.tags.contains("Notes")
    - '!file.path.contains("Templates")'
views:
  - type: table
    name: Table
    order:
      - file.name
      - file.mtime
      - status
      - related
      - note_purpose
      - story_title
      - priority
    columnSize:
      file.mtime: 233
