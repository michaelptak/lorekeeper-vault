filters:
  and:
    - or:
        - note_purpose.contains("Documentation")
        - note_purpose.contains("Vault")
        - file.path.contains("Notes/Documentation")
    - '!file.path.contains("Templates")'
views:
  - type: table
    name: Table
    order:
      - file.name
      - file.mtime
      - note_purpose
      - status
    sort:
      - property: status
        direction: ASC
    columnSize:
      file.mtime: 221
  - type: cards
    name: Cards
    image: note.art
